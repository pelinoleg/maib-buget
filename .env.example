# --- AI Categorization (optional) ---
# Claude API key for automatic transaction categorization
OPENAI_API_KEY=

# --- Telegram Bot (optional) ---
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=

# --- Tax Declaration ---
TAX_RATE=12
TAX_CHILD_DEDUCTION=9900
TAX_PERSONAL_DEDUCTION=29700

# --- Frontend Settings ---
# Default period preset: last_7_days, this_month, last_month, last_3_months, last_6_months, last_year
VITE_DEFAULT_PERIOD=last_month

# Backend API URL
# For local dev: http://localhost:8000/api
# For Docker: /api (proxied by nginx)
VITE_API_BASE=http://localhost:8000/api

# Date from which to check upload coverage (YYYY-MM)
COVERAGE_START=2025-01

# Transactions per page
VITE_PAGE_SIZE=200

# Base currency for conversions
VITE_BASE_CURRENCY=EUR
